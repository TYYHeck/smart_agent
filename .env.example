# ============================================
# SmartAgent 企业版 v2.0 环境变量配置
# 复制此文件为 .env 并填入你的配置
# ============================================

# --- LLM API Keys ---
# OpenAI (推荐)
OPENAI_API_KEY=sk-your-key-here
# DeepSeek (便宜、效果好)
DEEPSEEK_API_KEY=sk-your-key-here
# 阿里通义千问
DASHSCOPE_API_KEY=sk-your-key-here
# 智谱 GLM
ZHIPU_API_KEY=your-key-here

# --- MySQL 数据库 ---
# 完整连接 URL（优先级最高，设置此项则忽略下面的单独配置）
# DATABASE_URL=mysql+aiomysql://user:pass@host:3306/smart_agent?charset=utf8mb4
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smart_agent
DB_PASSWORD=smart_agent_pass
DB_NAME=smart_agent

# --- 认证 (JWT) ---
# 生产环境务必修改为强随机字符串!
JWT_SECRET_KEY=change-this-to-a-strong-random-string
JWT_EXPIRE_MINUTES=480
# 默认管理员账户
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@smartagent.local

# --- LangSmith 追踪 (可选) ---
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=smart_agent
