# ============================================================
# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 数据库 ──
# MySQL 连接信息（未设置 DATABASE_URL 时使用）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smart_agent
DB_PASSWORD=your_password_here
DB_NAME=smart_agent

# 或直接使用完整连接串（优先于上面各项）
# DATABASE_URL=mysql+aiomysql://smart_agent:password@127.0.0.1:3306/smart_agent?charset=utf8mb4

# ── LLM API Keys ──
# OpenAI 兼容
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问
QWEN_API_KEY=sk-your-qwen-key

# 智谱 GLM
ZHIPU_API_KEY=your-zhipu-key

# Ollama 本地（无需 API Key）
# OLLAMA_HOST=http://localhost:11434

# ── 认证 ──
# JWT 签名密钥（生产环境务必修改！）
JWT_SECRET_KEY=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员账户
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@smartagent.local

# ── 服务端口 ──
HOST=127.0.0.1
PORT=8080

# ── 日志 ──
LOG_LEVEL=INFO
LOG_DIR=./logs
# 生产环境建议关闭
LOG_JSON_FORMAT=false
